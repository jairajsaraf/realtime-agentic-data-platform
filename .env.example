# Copy to .env and adjust. All settings are read with the RTDP_ prefix.
# Defaults are tuned for LocalStack S3; change to switch backends.

# Storage backend: localstack | file | aws
RTDP_STORAGE_BACKEND=localstack

# --- S3 / object storage (localstack + aws backends) ---
# LocalStack edge endpoint. Ignored for the `aws` backend (real AWS is config-only:
# switch RTDP_STORAGE_BACKEND=aws and supply real credentials/region).
RTDP_S3_ENDPOINT_URL=http://localhost:4566
RTDP_S3_BUCKET=lakehouse
RTDP_S3_WAREHOUSE_PREFIX=warehouse
RTDP_AWS_REGION=us-east-1
RTDP_AWS_ACCESS_KEY_ID=test
RTDP_AWS_SECRET_ACCESS_KEY=test

# --- Local file warehouse (file backend / no-Docker fallback) ---
RTDP_LOCAL_WAREHOUSE_DIR=./_warehouse

# --- Catalog (pyiceberg SqlCatalog on SQLite) ---
RTDP_CATALOG_NAME=rtdp
RTDP_CATALOG_DB_PATH=./_warehouse/catalog.db
RTDP_NAMESPACE=bronze
RTDP_TABLE_NAME=opensky_state_vectors

# --- Data source: synthetic | opensky-live ---
RTDP_SOURCE=synthetic
# Only needed for opensky-live beyond the anonymous snapshot tier (OAuth2 client credentials):
# RTDP_OPENSKY_CLIENT_ID=
# RTDP_OPENSKY_CLIENT_SECRET=
