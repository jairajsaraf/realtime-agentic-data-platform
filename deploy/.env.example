# Example environment for the single-host deploy compose (deploy/docker-compose.yml).
# Copy to a LOCAL, gitignored `.env` (or inject via Doppler) and fill in real values.
# These are PLACEHOLDERS — never commit real credentials.

# --- backend selection ---
# file (default; no object storage needed) | aws (S3-compatible, e.g. MinIO via the `s3` profile)
RTDP_STORAGE_BACKEND=aws

# --- S3-compatible object storage (used when RTDP_STORAGE_BACKEND=aws) ---
# In-cluster MinIO endpoint (compose service name). For real AWS S3, leave this empty.
RTDP_S3_ENDPOINT_URL=http://minio:9000
RTDP_S3_BUCKET=lakehouse
RTDP_AWS_REGION=us-east-1
# For MinIO, set these equal to the MinIO root credentials below.
RTDP_AWS_ACCESS_KEY_ID=CHANGE_ME
RTDP_AWS_SECRET_ACCESS_KEY=CHANGE_ME

# --- MinIO root credentials (profile "s3") ---
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# --- MinIO object-data location (Compose/deployment-only; NOT an app Settings field) ---
# Selects the source of MinIO's /data mount in deploy/docker-compose.yml
# (`- "${RTDP_MINIO_DATA_PATH:-minio-data}:/data"`). Leave UNSET or EMPTY to keep the existing Docker
# named volume `minio-data` — the `:-` fallback applies when the variable is unset OR empty (this is
# the local/CI default and rollback protection; do not delete that volume during a migration). Set it
# to an ABSOLUTE host path to switch MinIO to a bind mount on a larger disk; that host filesystem must
# be mounted persistently and the destination directory pre-created with permissions the MinIO
# container can write. Render & inspect the effective mount before deploying (see deploy/README.md).
# RTDP_MINIO_DATA_PATH=/mnt/minio-data/minio

# --- stream cadence (optional; the writer is opt-in via the `ingestion` profile — see below) ---
RTDP_STREAM_INTERVAL_SECONDS=60

# --- published image & compose profiles (host deploy) ---
# On the host, point RTDP_IMAGE at the published GHCR image so `docker compose pull` fetches it
# instead of building. PIN an immutable reference — the commit SHA (or a digest), NOT `:latest` — so a
# queued/approved deploy can't pull a newer image than the one approved. The gated CI deploy passes
# the approved commit's SHA-pinned ref automatically, so keep RTDP_IMAGE OUT of Doppler — it is
# deployment-controlled and `host_deploy.sh` runs `doppler run --preserve-env=RTDP_IMAGE`, so the
# ambient approved ref wins even if one were stored as a secret. Set it here only for manual host
# runs. Locally, leave unset to build `rtdp:local` from the Dockerfile.
RTDP_IMAGE=ghcr.io/OWNER/REPO:<commit-sha>
# Profiles the host brings up (object storage + edge TLS + observability). Compose reads
# COMPOSE_PROFILES natively; host_deploy.sh defaults to this same set when unset. This set does NOT
# include `ingestion`, so the bare `docker compose up -d` the deploy runs will not select the `stream`
# writer — it stays stopped until you deliberately add `ingestion` here. (Explicitly targeting the
# `stream` service on the command line can still start it; the profile only prevents accidental startup.)
COMPOSE_PROFILES=s3,edge,observability

# --- edge / TLS (profile "edge": Caddy reverse proxy + automatic Let's Encrypt) ---
# Public hostname Caddy serves. Default `localhost` (internal CA) for local testing; set to the real
# domain on the host (DNS A-record -> droplet, ports 80/443 open) for an automatic Let's Encrypt cert.
RTDP_PUBLIC_HOSTNAME=example.me
# Host bind for the API's published port. Default 0.0.0.0 (local). On the public host set 127.0.0.1
# so port 8000 is NOT exposed to the internet — Caddy fronts TLS and reaches the API internally.
RTDP_API_BIND=127.0.0.1

# --- observability (profile "observability": Datadog Agent OTLP intake) — OFF by default ---
# Export turns on only when RTDP_OTEL_ENABLED=true AND the deployed image carries the [otel] extra.
# Set RTDP_OTEL_ENABLED=true on the host to ship traces to the Agent's OTLP gRPC receiver.
RTDP_OTEL_ENABLED=false
RTDP_OTEL_EXPORTER_OTLP_ENDPOINT=http://datadog-agent:4317
RTDP_OTEL_SERVICE_NAME=rtdp
# Datadog Agent — required for the Agent to start (the `observability` profile). Never commit a key.
DD_API_KEY=CHANGE_ME
DD_SITE=datadoghq.com
# Agent hostname (non-secret). DigitalOcean isn't an auto-detected cloud provider and no Docker socket
# is mounted, so the containerized Agent needs an explicit hostname or it exits. Compose defaults this
# to rtdp-demo when unset; set it here only to override.
DD_HOSTNAME=rtdp-demo

# --- deploy liveness probe (used by deploy/host_deploy.sh) ---
# URL the post-deploy probe polls. Defaults to the liveness endpoint /livez (200 whenever the API
# process serves, no data required) so a fresh host deploys without starting ingestion; data
# readiness stays on /health. Same variable name — only the default changed. Plain local HTTP.
DEPLOY_HEALTH_URL=http://127.0.0.1:8000/livez
