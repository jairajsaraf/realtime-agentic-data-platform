{
  "title": "rtdp — single-host demo dashboard",
  "description": "Overview for the rtdp single-host demo (service:rtdp, host:rtdp-demo, Datadog US5): request rate, 5xx responses, latency percentiles, and /health check status. Contains no API keys, org IDs, or secrets.",
  "layout_type": "ordered",
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "Request rate — service:rtdp (hits/s)",
        "show_legend": true,
        "requests": [
          {
            "display_type": "line",
            "q": "sum:trace.http.server.request.hits{service:rtdp}.as_rate()"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "5xx errors — service:rtdp (count)",
        "show_legend": true,
        "requests": [
          {
            "display_type": "bars",
            "q": "sum:trace.http.server.request.hits{service:rtdp,http.status_code:5*}.as_count()"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Request latency — service:rtdp (p50/p95, seconds)",
        "show_legend": true,
        "requests": [
          {
            "display_type": "line",
            "q": "p50:trace.http.server.request{service:rtdp}"
          },
          {
            "display_type": "line",
            "q": "p95:trace.http.server.request{service:rtdp}"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "check_status",
        "check": "http.can_connect",
        "grouping": "cluster",
        "group_by": ["host"],
        "tags": ["instance:rtdp_health"],
        "title": "/health check status"
      }
    }
  ]
}
